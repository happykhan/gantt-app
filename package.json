{
  "name": "gantt-app",
  "private": true,
  "version": "1.0.42",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run check:size",
    "check:size": "node scripts/check-bundle-size.mjs",
    "ci": "npm audit --omit=dev --audit-level=moderate && npm run lint && npm test && npm run build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:a11y": "npm run build && playwright test e2e/accessibility.spec.js",
    "test:e2e:local": "npm run build && playwright test",
    "test:e2e:preview": "playwright test e2e/preview.spec.js --project=desktop-light",
    "test:watch": "vitest",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "dependencies": {
    "@genomicx/ui": "^0.9.1",
    "@tailwindcss/vite": "^4.2.2",
    "jspdf": "^4.2.1",
    "papaparse": "^5.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.18.1",
    "tailwindcss": "^4.2.2",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "dompurify": "^3.4.12",
    "postcss": "^8.5.22"
  }
}
